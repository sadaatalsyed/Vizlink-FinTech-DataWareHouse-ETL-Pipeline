# Vizlink ETL - Environment Configuration
# Copy this file to config.env and fill in your values
# DO NOT commit config.env to Git (it is in .gitignore)

# Source Database (OLTP - vizlink-live)
SOURCE_SERVER=DESKTOP-ON935M4\MSSQLSERVER01
SOURCE_DB=vizlink-live
SOURCE_TRUSTED=yes
# Uncomment below if using SQL auth instead of Windows auth:
# SOURCE_UID=your_username
# SOURCE_PWD=your_password

# Destination Database (OLAP - VDWH_Auto)
DEST_SERVER=DESKTOP-ON935M4\MSSQLSERVER01
DEST_DB=VDWH_Auto
DEST_TRUSTED=yes
# DEST_UID=your_username
# DEST_PWD=your_password
